      "text": "@human_feedback decorator\n        ↓\ndecorator stacking order\n        ↓\nConsoleProvider vs WebhookProvider\n        ↓\nWebhookProvider = pause + save + metadata\n        ↓\nHumanFeedbackPending = official pause mechanism\n        ↓\nPendingFeedbackContext = all flow info at pause point\n        ↓\nflow_id journey:\n    generated → frontend → path parameter → from_pending()\n        ↓\nCrew node vs HITL node separation\n        ↓\ndirect call loop pattern\n        ↓\nfeedback → state → writer task → AI improves\n        ↓\ntwo endpoints /generate + /feedback\n        ↓\nfull Streamlit + FastAPI + CrewAI architecture",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "@human_feedback decorator\n        ↓\ndecorator stacking order\n        ↓\nConsoleProvider vs WebhookProvider\n        ↓\nWebhookProvider = pause + save + metadata\n        ↓\nHumanFeedbackPending = official pause mechanism\n        ↓\nPendingFeedbackContext = all flow info at pause point\n        ↓\nflow_id journey:\n    generated → frontend → path parameter → from_pending()\n        ↓\nCrew node vs HITL node separation\n        ↓\ndirect call loop pattern\n        ↓\nfeedback → state → writer task → AI improves\n        ↓\ntwo endpoints /generate + /feedback\n        ↓\nfull Streamlit + FastAPI + CrewAI architecture",
      "autoResize": true,
      "lineHeight": 1.35
    },
