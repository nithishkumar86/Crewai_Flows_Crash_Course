      "updated": 1774096912232,
      "link": null,
      "locked": false,
      "text": "POST /generate          ✅  flow started\ngenerate_blog           ✅  Crew ran, blog generated\nreview_blog             ✅  HITL triggered, flow paused\n                            flow_id = e8472948-f4d1-4e7b-8f04-4c871498f82f\n\nyou typed \"approved\"\nPOST /feedback/{flow_id} ✅  feedback received\n\nreview_blog             ✅  Completed\n✅ Blog Approved!\non_approved()           ✅  Running → Completed\n\nFlow Execution Completed ✅\nID: e8472948-f4d1-4e7b-8f04-4c871498f82f  ← same flow_id throughout!",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "POST /generate          ✅  flow started\ngenerate_blog           ✅  Crew ran, blog generated\nreview_blog             ✅  HITL triggered, flow paused\n                            flow_id = e8472948-f4d1-4e7b-8f04-4c871498f82f\n\nyou typed \"approved\"\nPOST /feedback/{flow_id} ✅  feedback received\n\nreview_blog             ✅  Completed\n✅ Blog Approved!\non_approved()           ✅  Running → Completed\n\nFlow Execution Completed ✅\nID: e8472948-f4d1-4e7b-8f04-4c871498f82f  ← same flow_id throughout!",
      "autoResize": true,
      "lineHeight": 1.35
    },
