      "link": null,
      "locked": false,
      "text": "class WebhookProvider(HumanFeedbackProvider):\n    \"\"\"Provider that pauses flow and waits for webhook callback.\"\"\"\n\n    def __init__(self, webhook_url: str):\n        self.webhook_url = webhook_url\n\n    def request_feedback(self, context: PendingFeedbackContext, flow: Flow) -> str:\n        # Notify external system (e.g., send Slack message, create ticket)\n        self.send_notification(context)\n\n        # Pause execution - framework handles persistence automatically\n        raise HumanFeedbackPending(\n            context=context,\n            callback_info={\"webhook_url\": f\"{self.webhook_url}/{context.flow_id}\"}\n        )",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "class WebhookProvider(HumanFeedbackProvider):\n    \"\"\"Provider that pauses flow and waits for webhook callback.\"\"\"\n\n    def __init__(self, webhook_url: str):\n        self.webhook_url = webhook_url\n\n    def request_feedback(self, context: PendingFeedbackContext, flow: Flow) -> str:\n        # Notify external system (e.g., send Slack message, create ticket)\n        self.send_notification(context)\n\n        # Pause execution - framework handles persistence automatically\n        raise HumanFeedbackPending(\n            context=context,\n            callback_info={\"webhook_url\": f\"{self.webhook_url}/{context.flow_id}\"}\n        )",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "x-Kyi74MO0DQxMfHhtrxN",
      "type": "text",
      "x": 243.33331298828125,
      "y": 1056.6666437255026,
      "width": 677.6990966796875,
      "height": 432,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
