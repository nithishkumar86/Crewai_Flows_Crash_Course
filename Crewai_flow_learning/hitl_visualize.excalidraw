      "seed": 840442630,
      "version": 88,
      "versionNonce": 1275474075,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774285239397,
      "link": null,
      "locked": false,
      "text": "The actual solution CrewAI provides:\n\npython@start(\"retry\")   ←  this is the KEY design!\n\n@start() parentheses can accept a trigger name — making it \nboth entry point AND re-entry point!",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The actual solution CrewAI provides:\n\npython@start(\"retry\")   ←  this is the KEY design!\n\n@start() parentheses can accept a trigger name — making it \nboth entry point AND re-entry point!",
      "autoResize": true,
      "lineHeight": 1.25
    },
