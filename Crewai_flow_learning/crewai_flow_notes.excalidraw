    {
      "id": "vgrEk2B80K6T31m6X5XDU",
      "type": "text",
      "x": 60.87234878540039,
      "y": 1485.2212996438711,
      "width": 631.2191162109375,
      "height": 108,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
