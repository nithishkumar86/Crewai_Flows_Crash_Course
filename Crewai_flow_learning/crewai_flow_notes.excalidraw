      "link": null,
      "locked": false,
      "text": "Human Feedback in Flows",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Human Feedback in Flows",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "sc9FgPtSqyawDOb_y7ZKb",
      "type": "text",
      "x": 90.4296875,
      "y": 160.03688049316406,
      "width": 698.0391845703125,
      "height": 324,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a2",
      "roundness": null,
      "seed": 295120436,
      "version": 51,
      "versionNonce": 67997876,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773920652777,
      "link": null,
      "locked": false,
      "text": "The @human_feedback decorator enables human-in-the-loop (HITL) \nworkflows directly within CrewAI Flows.\n\n It allows you to pause flow execution, present output to a human for review, \ncollect their feedback, and optionally route to different listeners based on the\n feedback outcome.\n\nThis is particularly valuable for:\nQuality assurance: Review AI-generated content before it’s used downstream\nDecision gates: Let humans make critical decisions in automated workflows\nApproval workflows: Implement approve/reject/revise patterns\nInteractive refinement: Collect feedback to improve outputs iteratively",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The @human_feedback decorator enables human-in-the-loop (HITL) \nworkflows directly within CrewAI Flows.\n\n It allows you to pause flow execution, present output to a human for review, \ncollect their feedback, and optionally route to different listeners based on the\n feedback outcome.\n\nThis is particularly valuable for:\nQuality assurance: Review AI-generated content before it’s used downstream\nDecision gates: Let humans make critical decisions in automated workflows\nApproval workflows: Implement approve/reject/revise patterns\nInteractive refinement: Collect feedback to improve outputs iteratively",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "eURLnT14MeCIFHNmmC-Gi",
      "type": "text",
      "x": 79.07980346679688,
      "y": 563.6284268432199,
      "width": 835.8780517578125,
      "height": 459,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a3",
      "roundness": null,
      "seed": 2038253876,
      "version": 951,
      "versionNonce": 580207796,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773920689878,
      "link": null,
      "locked": false,
      "text": "    Parameter         Type                     Required             Description\n\n    message           str                         Yes                     The message shown to the human \n                                                                                         alongside the method output\n\nemit                       Sequence[str]       No                      List of possible outcomes. Feedback is \n                                                                                      collapsed to one of these, \n                                                                                        which triggers @listen  decorators\n\nllm                         str | BaseLLM      When emit        LLM used to interpret feedback and \n                                                             specified            map to an outcome\n\ndefault_outcome      str                     No                        Outcome to use if no feedback provided. \n                                                                                          Must be in emit\n\nmetadata                 dict                    No                         Additional data for enterprise \n                                                                                          integrations",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "    Parameter         Type                     Required             Description\n\n    message           str                         Yes                     The message shown to the human \n                                                                                         alongside the method output\n\nemit                       Sequence[str]       No                      List of possible outcomes. Feedback is \n                                                                                      collapsed to one of these, \n                                                                                        which triggers @listen  decorators\n\nllm                         str | BaseLLM      When emit        LLM used to interpret feedback and \n                                                             specified            map to an outcome\n\ndefault_outcome      str                     No                        Outcome to use if no feedback provided. \n                                                                                          Must be in emit\n\nmetadata                 dict                    No                         Additional data for enterprise \n                                                                                          integrations",
      "autoResize": true,
      "lineHeight": 1.35
    },
