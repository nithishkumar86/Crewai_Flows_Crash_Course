    {
      "id": "osWB6EwPJj8WyVZAf3Yhi",
      "type": "text",
      "x": 62.64678599089851,
      "y": 128.3950021252036,
      "width": 496.35931396484375,
      "height": 135,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
